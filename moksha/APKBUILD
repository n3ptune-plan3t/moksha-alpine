pkgname=moksha
_commit="74abe79c05c1ad81acdeb5dca855e55284a33268"
pkgver=0.4.2_git20260616
pkgrel=1
pkgdesc="A fork of the E17 window manager used by Bodhi Linux, git snapshot"
url="https://mokshadesktop.org"
arch="x86_64 x86"
license="BSD-2-Clause"
depends="
	desktop-file-utils
	efl>=1.20
	xcb-util-keysyms
	!enlightenment
	"
makedepends="
	autoconf>=2.71
	automake
	libtool
	pkgconf
	efl-dev
	glib-dev
	openssl-dev
	libpng-dev
	harfbuzz-dev
	fribidi-dev
	fontconfig-dev
	libsndfile-dev
	pulseaudio-dev
	bullet-dev
	libxcb-dev
	xcb-util-keysyms-dev
	libx11-dev
	udisks2-dev
	doxygen
	"

# No optdepends= mechanism in APKBUILD. These are genuinely optional
# runtime features -- install manually if you want them:
#   acpid       -- power events on laptop lid close
#   bc          -- calculator in the everything module
#   connman     -- network module
#   doxygen     -- build documentation
#   gdb         -- crash backtraces
#   geoclue2    -- geolocation module

options="!check"
subpackages="$pkgname-dev"
source="$pkgname-$_commit.tar.gz::https://github.com/JeffHoogland/moksha/archive/$_commit.tar.gz"
builddir="$srcdir/moksha-$_commit"

build() {
	./autogen.sh
	./configure \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--localstatedir=/var
	make
}

check() {
	make -k check
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
6f59081698c38aaa830b83d3dc591845e3570854e6e3bcb43090a7e5f98206815ed07c17bf35b59c24137d71f878207ccf9646fd06723ad709945e77acda2d6c  moksha-74abe79c05c1ad81acdeb5dca855e55284a33268.tar.gz
"
